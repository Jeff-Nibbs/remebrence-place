# Copy this file to .env (for local testing) or paste these as environment
# variables in your hosting dashboard. Never commit real secrets.

# --- Admin ---
# Key that protects the "download everything" link. Pick something long.
ADMIN_KEY=change-me-to-a-long-secret

# Max size per uploaded file, in MB.
MAX_FILE_MB=500

# --- Cloudflare R2 (where photos/videos are stored) ---
# Leave these blank to store files on local disk instead (for local testing).
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=remembrance-media

# Optional. Only set this if you made the bucket public (custom domain or the
# r2.dev URL). If left blank, the server hands out temporary signed links,
# which keeps the media private. Example: https://media.yourdomain.com
# R2_PUBLIC_BASE_URL=
